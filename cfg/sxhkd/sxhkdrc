# ============================================================
# Shortcut Umum
# ============================================================

# Terminal
ctrl + alt + t
	alacritty --working-directory ~
ctrl + Return
	alacritty --working-directory ~

# Browser
ctrl + alt + b
	env GDK_DPI_SCALE=0.75 google-chrome --ozone-platform=x11

# Discord
ctrl + alt + d
	discord --enable-transparent-visuals

# File manager
ctrl + alt + e
	env GDK_DPI_SCALE=0.75 nautilus

# Text editor
ctrl + alt + c
	env GDK_DPI_SCALE=0.75 code --ozone-platform=x11

# App launcher
ctrl + d
	rofi -show drun -theme ~/.config/rofi/launcher.rasi
ctrl + space
	dmenu_run

# Power menu
ctrl + p
	~/.config/polybar/scripts/powermenu.sh

# Lockscreen
ctrl + alt + l
	~/.local/bin/lock.sh

# Clipboard history
ctrl + v
	CM_LAUNCHER=rofi clipmenu -theme ~/.config/rofi/launcher.rasi

# Random wallpaper
ctrl + alt + w
	~/.local/bin/wallrandom.sh

# Tutup window (seperti Windows Alt+F4)
alt + F4
	bspc node -c

# Reload sxhkd
ctrl + Escape
	pkill -USR1 -x sxhkd

# ============================================================
# Screenshot
# ============================================================

Print
	~/.local/bin/screenshot.sh

# ============================================================
# Volume (PipeWire)
# ============================================================

XF86AudioRaiseVolume
	pactl set-sink-volume @DEFAULT_SINK@ +5%

XF86AudioLowerVolume
	pactl set-sink-volume @DEFAULT_SINK@ -5%

XF86AudioMute
	pactl set-sink-mute @DEFAULT_SINK@ toggle

# ============================================================
# Brightness
# ============================================================

XF86MonBrightnessUp
	brightnessctl set +5%

XF86MonBrightnessDown
	brightnessctl set 5%-

# ============================================================
# BSPWM — Window
# ============================================================

# Tutup / kill window
ctrl + w
	bspc node -c

ctrl + shift + w
	bspc node -k

# Layout tiled / floating / fullscreen / pseudo-tiled
ctrl + {t,s,f,shift + t}
	bspc node -t {tiled,floating,fullscreen,pseudo_tiled}

# Node flags
ctrl + ctrl + {m,x,y,z}
	bspc node -g {marked,locked,sticky,private}

# ============================================================
# BSPWM — Fokus & Pindah
# ============================================================

# Fokus dengan arrow (familiar)
ctrl + {Left,Down,Up,Right}
	bspc node -f {west,south,north,east}

# Fokus dengan vim keys
ctrl + {h,j,k,l}
	bspc node -f {west,south,north,east}

# Pindah window dengan vim keys
ctrl + shift + {h,j,k,l}
	bspc node -s {west,south,north,east}

# Pindah window dengan arrow
ctrl + shift + {Left,Down,Up,Right}
	bspc node -s {west,south,north,east}

# Swap dengan window terbesar
ctrl + g
	bspc node -s biggest.window

# ============================================================
# BSPWM — Desktop
# ============================================================

# Pindah desktop
ctrl + {1-9,0}
	bspc desktop -f '^{1-9,10}'

# Kirim window ke desktop
ctrl + shift + {1-9,0}
	bspc node -d '^{1-9,10}'

# Desktop sebelumnya / berikutnya
ctrl + bracket{left,right}
	bspc desktop -f {prev,next}.local

# Toggle monocle
ctrl + m
	bspc desktop -l next

# ============================================================
# BSPWM — Resize
# ============================================================

ctrl + alt + {Left,Down,Up,Right}
	bspc node -z {left -30 0,bottom 0 30,top 0 -30,right 30 0}

ctrl + alt + shift + {Left,Down,Up,Right}
	bspc node -z {right -30 0,top 0 30,bottom 0 -30,left 30 0}

# ============================================================
# BSPWM — Preselect
# ============================================================

ctrl + ctrl + {h,j,k,l}
	bspc node -p {west,south,north,east}

ctrl + ctrl + {1-9}
	bspc node -o 0.{1-9}

ctrl + ctrl + space
	bspc node -p cancel

# ============================================================
# BSPWM — Session
# ============================================================

ctrl + alt + r
	bspc wm -r

ctrl + alt + q
	bspc quit

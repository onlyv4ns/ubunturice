[global]
    monitor             = 0
    follow              = mouse
    width               = 320
    height              = 120
    origin              = top-right
    offset              = 16x50
    scale               = 0
    notification_limit  = 5

    progress_bar        = true
    progress_bar_height = 6
    progress_bar_frame_width = 0
    progress_bar_min_width = 150
    progress_bar_max_width = 280
    progress_bar_corner_radius = 4

    indicate_hidden     = yes
    transparency        = 8
    separator_height    = 2
    padding             = 10
    horizontal_padding  = 14
    text_icon_padding   = 8
    frame_width         = 1
    frame_color         = "#2d3f45"
    separator_color     = frame
    sort                = yes

    font                = JetBrainsMono Nerd Font 10
    line_height         = 2
    markup              = full
    format              = "<b>%s</b>\n%b"
    alignment           = left
    vertical_alignment  = center
    show_age_threshold  = 60
    ellipsize           = middle
    ignore_newline      = no
    stack_duplicates    = true
    hide_duplicate_count = false
    show_indicators     = yes

    icon_theme          = Papirus-Dark
    enable_recursive_icon_lookup = true
    icon_position       = left
    min_icon_size       = 32
    max_icon_size       = 48
    icon_corner_radius  = 6

    sticky_history      = yes
    history_length      = 20

    browser             = /usr/bin/xdg-open
    always_run_script   = true
    title               = Dunst
    class               = Dunst
    corner_radius       = 10
    ignore_dbusclose    = false
    force_xwayland      = false
    force_xinerama      = false
    mouse_left_click    = close_current
    mouse_middle_click  = do_action, close_current
    mouse_right_click   = close_all

[experimental]
    per_monitor_dpi = false

[urgency_low]
    background  = "#cc0a1114"
    foreground  = "#dadada"
    highlight   = "#67b0e8"
    frame_color = "#1d2527"
    timeout     = 4
    icon        = dialog-information

[urgency_normal]
    background  = "#cc141b1e"
    foreground  = "#dadada"
    highlight   = "#67b0e8"
    frame_color = "#67b0e8"
    timeout     = 6
    icon        = dialog-information

[urgency_critical]
    background  = "#cc141b1e"
    foreground  = "#dadada"
    highlight   = "#e57474"
    frame_color = "#e57474"
    timeout     = 0
    icon        = dialog-error

[volume]
    summary = "Volume*"
    timeout = 2

[screenshot]
    summary = "Screenshot*"
    timeout = 3

[brightness]
    summary = "Brightness*"
    timeout = 2
